-- Auto-generated by OrderFlow Pipeline Factory
-- Source: factory/sources/{{ config.source.name }}.yaml
-- Silver layer table with type transformations
-- PII columns get _hash suffix
-- Timestamp columns get _dt suffix with DateTime type
-- ClickHouse: clickhouse.clickhouse.svc.cluster.local (namespace-qualified)

CREATE TABLE IF NOT EXISTS silver.{{ config.source.name }}
(
{% for col in config.columns %}
{% if col.get('pii') %}
    {{ col.name }}_hash {{ col.clickhouse_type }},
{% elif col.get('is_timestamp') %}
    {{ col.name }}_dt DateTime,
{% else %}
    {{ col.name }} {{ col.clickhouse_type }},
{% endif %}
{% endfor %}
    is_deleted UInt8 DEFAULT 0,
    updated_at_dt DateTime DEFAULT now()
)
ENGINE = {{ config.silver.engine }}{% if config.silver.engine == 'ReplacingMergeTree' %}({{ config.silver.version_column }}){% endif %}

{% if config.silver.get('partition_by') %}PARTITION BY {{ config.silver.partition_by }}{% endif %}

ORDER BY ({{ config.silver.order_by | join(', ') }})
SETTINGS allow_nullable_key = 1, index_granularity = 8192;
