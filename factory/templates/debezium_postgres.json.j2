{# Auto-generated by OrderFlow Pipeline Factory #}
{# Source: factory/sources/{{ config.source.name }}.yaml #}
{# NOTE: Despite .json.j2 extension, this generates a Strimzi KafkaConnector CRD (YAML) #}
{# Deviation from original plan: All connectors use Strimzi CRDs, not REST API JSON (Phase 2 Deviation 11) #}
{# DNS: postgres.databases.svc.cluster.local (namespace-qualified) #}
{# PG password: debezium_pg_pass (from K8s secret) #}
{# Columns use FLAT naming from Phase 2 Flatten SMT: after_id, after_name, etc. #}
---
apiVersion: kafka.strimzi.io/v1beta2
kind: KafkaConnector
metadata:
  name: orderflow-postgres-source-{{ config.source.name }}
  namespace: kafka
  labels:
    strimzi.io/cluster: orderflow-connect
spec:
  class: io.debezium.connector.postgresql.PostgresConnector
  tasksMax: 1
  config:
    database.hostname: postgres.databases.svc.cluster.local
    database.port: "5432"
    database.user: debezium
    database.password: debezium_pg_pass
    database.dbname: {{ config.source.connection.database }}
    database.server.name: {{ config.source.connection.server_name }}
    table.include.list: {{ config.source.connection.schema }}.{{ config.source.connection.table }}
    topic.prefix: {{ config.source.connection.server_name }}
    plugin.name: pgoutput
    slot.name: {{ config.source.name }}_slot
    publication.name: {{ config.source.name }}_pub
    publication.autocreate.mode: filtered
    key.converter: io.confluent.connect.avro.AvroConverter
    key.converter.schema.registry.url: http://schema-registry.kafka.svc.cluster.local:8081
    value.converter: io.confluent.connect.avro.AvroConverter
    value.converter.schema.registry.url: http://schema-registry.kafka.svc.cluster.local:8081
    decimal.handling.mode: double
    transforms: {% if pii_columns %}HashPII,{% endif %}Flatten
{% if pii_columns %}
    transforms.HashPII.type: com.orderflow.connect.transforms.HashPII
    transforms.HashPII.field_path: after
    transforms.HashPII.fields: {{ pii_columns | join(',') }}
{% endif %}
    transforms.Flatten.type: org.apache.kafka.connect.transforms.Flatten$Value
    transforms.Flatten.delimiter: "_"
