      "pluginVersion": "10.0.0",
      "id": 1,
      "title": "Slow Queries (>1s, last 7d)",
      "type": "table",
      "targets": [
        {
          "datasource": {
            "type": "vertamedia-clickhouse-datasource",
            "uid": "PDEE91DDB90597936"
          },
          "format": "table",
          "rawSql": "SELECT query_id, left(query, 80) AS query_preview, query_duration_ms, read_rows FROM system.query_log WHERE query_duration_ms > 1000 AND event_time >= now() - INTERVAL 7 DAY AND type = 'QueryFinish' ORDER BY query_duration_ms DESC LIMIT 20",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {
        "type": "vertamedia-clickhouse-datasource",
        "uid": "PDEE91DDB90597936"
      },
      "fieldConfig": {
