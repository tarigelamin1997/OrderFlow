          "format": "table",
          "rawSql": "SELECT entity, check_type, sum(failure_count) AS total_failures FROM gold.pii_audit_log WHERE audit_timestamp >= now() - INTERVAL 7 DAY GROUP BY entity, check_type ORDER BY total_failures DESC",
