      },
      "pluginVersion": "10.0.0",
      "id": 2,
      "title": "Storage by Database",
      "type": "table",
      "targets": [
        {
          "datasource": {
            "type": "vertamedia-clickhouse-datasource",
            "uid": "PDEE91DDB90597936"
          },
          "format": "table",
          "rawSql": "SELECT database, formatReadableSize(sum(bytes_on_disk)) AS disk_usage, sum(rows) AS total_rows FROM system.parts WHERE active = 1 GROUP BY database ORDER BY sum(bytes_on_disk) DESC",
          "refId": "A"
        }
      ]
