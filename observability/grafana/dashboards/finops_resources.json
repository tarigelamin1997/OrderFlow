      "id": 1,
      "title": "Total DAG Runs per Day (last 7d)",
      "type": "table",
      "targets": [
        {
          "datasource": {
            "type": "vertamedia-clickhouse-datasource",
            "uid": "PDEE91DDB90597936"
          },
          "format": "table",
          "rawSql": "SELECT toDate(event_timestamp) AS run_date, dag_id, count() AS runs FROM gold.dag_run_log WHERE event_timestamp >= now() - INTERVAL 7 DAY GROUP BY run_date, dag_id ORDER BY run_date DESC, runs DESC",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {
        "type": "vertamedia-clickhouse-datasource",
